---
// Experience.astro
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import experiencesData from '../data/experience.json';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Helper to safely render markdown bold syntax to HTML
const renderMarkdownBold = (text: string) => {
  return text.replace(
    /\*\*(.*?)\*\*/g,
    '<strong class="font-semibold text-slate-900 dark:text-white">$1</strong>'
  );
};

const experiences = experiencesData.map((exp: any) => ({
  company: exp.company,
  role: exp.role[lang] as string,
  period: exp.period[lang] as string,
  bullets: exp.bullets[lang] as string[],
}));
---

<section id="experience" class="py-24 sm:py-32">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl lg:mx-0 mb-16">
      <h2
        class="text-3xl font-bold tracking-tight text-slate-900 dark:text-white sm:text-4xl"
      >
        {t('experience.title')}
      </h2>
      <div class="mt-4 h-1 w-20 bg-primary-500 rounded"></div>
    </div>

    <div class="mx-auto max-w-4xl space-y-16">
      {
        experiences.map((exp) => (
          <div class="relative pl-8 sm:pl-32 py-6 group">
            {/* Timeline line */}
            <div class="absolute left-0 sm:left-[7.5rem] top-0 bottom-0 w-px bg-slate-200 dark:bg-slate-700 group-last:bottom-auto group-last:h-full" />

            {/* Timeline dot */}
            <div class="absolute left-[-4px] sm:left-[calc(7.5rem-4px)] top-8 h-2.5 w-2.5 rounded-full bg-primary-500 ring-4 ring-white dark:ring-gray-900 z-10" />

            <div class="flex flex-col sm:flex-row sm:items-start gap-y-2 sm:gap-x-8 mb-6">
              {/* Period */}
              <time class="sm:absolute sm:left-0 sm:top-7 sm:w-24 sm:text-right text-sm font-medium text-slate-500 dark:text-slate-400">
                {exp.period}
              </time>

              <div class="flex-auto">
                <h3 class="text-xl font-bold text-slate-900 dark:text-white">
                  {exp.role}
                </h3>
                <p class="text-lg font-medium text-primary-600 dark:text-primary-400 mt-1">
                  {exp.company}
                </p>
              </div>
            </div>

            <ul class="space-y-3 list-none pl-0 text-slate-600 dark:text-slate-300">
              {exp.bullets.map((bullet: string) => (
                <li class="relative pl-6">
                  <span class="absolute left-0 top-[0.4rem] text-primary-500 w-4 h-4 text-center leading-4 text-xs">
                    ▹
                  </span>
                  <span set:html={renderMarkdownBold(bullet)} />
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>

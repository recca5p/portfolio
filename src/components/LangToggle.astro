---
// LangToggle.astro
import { getLangFromUrl, ui } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);

// A simple way to switch correctly keeping the current pathname
const switchLangPath = (targetLang: string) => {
  const segments = Astro.url.pathname.split('/');

  // If we are currently at a mapped language root (e.g. /vi/about)
  if (segments[1] in ui) {
    segments[1] = targetLang;
  } else {
    // If we are at the default language root without prefix (e.g. /about)
    segments.splice(1, 0, targetLang);
  }

  // Remove trailing slashes securely and format back to path
  let newPath = segments.join('/').replace(/\/$/, '');

  // Edge case for root
  if (newPath === '') newPath = `/${targetLang}`;

  return newPath;
};
---

<div class="relative inline-block text-left group">
  <button
    type="button"
    class="inline-flex justify-center w-full px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-gray-100 focus:ring-primary-500 dark:bg-gray-800 dark:text-gray-200 dark:border-gray-600 dark:hover:bg-gray-700"
    id="options-menu"
  >
    {lang === 'en' ? '🇺🇸 ENG' : '🇻🇳 VIE'}
    <!-- Heroicon name: solid/chevron-down -->
    <svg
      class="-mr-1 ml-2 h-5 w-5"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 20 20"
      fill="currentColor"
      aria-hidden="true"
    >
      <path
        fill-rule="evenodd"
        d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z"
        clip-rule="evenodd"></path>
    </svg>
  </button>

  <div
    class="origin-top-right absolute right-0 mt-2 w-28 rounded-md shadow-lg bg-white dark:bg-gray-800 ring-1 ring-black ring-opacity-5 invisible opacity-0 group-hover:visible group-hover:opacity-100 transition-all duration-300 ease-in-out z-50"
  >
    <div
      class="py-1"
      role="menu"
      aria-orientation="vertical"
      aria-labelledby="options-menu"
    >
      <a
        href={switchLangPath('en')}
        class={`block px-4 py-2 text-sm ${lang === 'en' ? 'font-bold text-primary-600 dark:text-primary-400' : 'text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700'}`}
        role="menuitem">🇺🇸 English</a
      >
      <a
        href={switchLangPath('vi')}
        class={`block px-4 py-2 text-sm ${lang === 'vi' ? 'font-bold text-primary-600 dark:text-primary-400' : 'text-gray-700 dark:text-gray-200 hover:bg-gray-100 dark:hover:bg-gray-700'}`}
        role="menuitem">🇻🇳 Tiếng Việt</a
      >
    </div>
  </div>
</div>

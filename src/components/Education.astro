---
// Education.astro
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="education" class="py-24 sm:py-32 bg-gray-800/30">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
      <!-- Education -->
      <div>
        <div class="mb-10">
          <h2 class="text-2xl font-bold tracking-tight text-white">
            {t('education.title')}
          </h2>
          <div class="mt-4 h-1 w-12 bg-primary-500 rounded"></div>
        </div>

        <div
          class="bg-gray-800 rounded-2xl p-8 shadow-sm ring-1 ring-gray-100/10"
        >
          <div
            class="flex flex-col sm:flex-row sm:items-center justify-between mb-4 gap-y-2"
          >
            <h3 class="text-lg font-bold text-white">
              Ton Duc Thang University
            </h3>
            <span
              class="text-sm font-medium text-primary-400 bg-primary-900/20 px-3 py-1 rounded-full w-fit"
              >2018 - 2023</span
            >
          </div>

          <p class="text-lg font-medium text-slate-200 mb-2">
            {t('education.degree')}
          </p>

          <div class="flex items-center text-sm text-slate-400 mt-4">
            <svg
              class="mr-2 h-5 w-5 text-slate-400"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 20 20"
              fill="currentColor"
            >
              <path
                fill-rule="evenodd"
                d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z"
                clip-rule="evenodd"></path>
            </svg>
            {t('education.location')}
          </div>
        </div>
      </div>

      <!-- Certifications -->
      <div>
        <div class="mb-10">
          <h2 class="text-2xl font-bold tracking-tight text-white">
            {t('education.certTitle')}
          </h2>
          <div class="mt-4 h-1 w-12 bg-primary-500 rounded"></div>
        </div>

        <div class="space-y-6">
          <!-- Cert 1 -->
          <div
            class="bg-gray-800 rounded-xl p-6 shadow-sm ring-1 ring-gray-100/10 flex items-start gap-4"
          >
            <div class="bg-blue-900/20 p-3 rounded-lg flex-shrink-0">
              <svg
                class="w-6 h-6 text-blue-400"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                ></path></svg
              >
            </div>
            <div>
              <h3 class="text-base font-bold text-white">
                Power Platform Developer Associate
              </h3>
              <p class="text-sm text-slate-400 mt-1">Microsoft</p>
            </div>
          </div>

          <!-- Language 1 -->
          <div
            class="bg-gray-800 rounded-xl p-6 shadow-sm ring-1 ring-gray-100/10 flex items-start gap-4"
          >
            <div class="bg-primary-900/20 p-3 rounded-lg flex-shrink-0">
              <svg
                class="w-6 h-6 text-primary-400"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"
                ></path></svg
              >
            </div>
            <div>
              <h3 class="text-base font-bold text-white">IELTS 6.5 (IDP)</h3>
              <p class="text-sm text-slate-400 mt-1">
                {t('education.englishProficiency')}
              </p>
            </div>
          </div>

          <!-- Language 2 -->
          <div
            class="bg-gray-800 rounded-xl p-6 shadow-sm ring-1 ring-gray-100/10 flex items-start gap-4"
          >
            <div class="bg-primary-900/20 p-3 rounded-lg flex-shrink-0">
              <svg
                class="w-6 h-6 text-primary-400"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129"
                ></path></svg
              >
            </div>
            <div>
              <h3 class="text-base font-bold text-white">TOEIC 700+</h3>
              <p class="text-sm text-slate-400 mt-1">
                {t('education.englishProficiency')}
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

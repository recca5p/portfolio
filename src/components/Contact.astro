---
// Contact.astro
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const phone = '+84779342459';
const phoneDisplay = '+84 779 342 459';
const email = 'phatvo73.dev@gmail.com';
const linkedinUrl = 'https://www.linkedin.com/in/tan-phat-vo-51ba10272/';
const whatsappUrl = `https://wa.me/${phone.replace('+', '')}`;
const zaloUrl = `https://zalo.me/${phone.replace('+', '')}`;

// QR code via free API
const whatsappQr = `https://api.qrserver.com/v1/create-qr-code/?size=160x160&data=${encodeURIComponent(whatsappUrl)}&bgcolor=1f2937&color=14b8a6`;
const zaloQr = `https://api.qrserver.com/v1/create-qr-code/?size=160x160&data=${encodeURIComponent(zaloUrl)}&bgcolor=1f2937&color=14b8a6`;
---

<section id="contact" class="px-6 py-24 sm:py-32 lg:px-8 bg-gray-800/30">
  <div class="mx-auto max-w-2xl text-center">
    <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
      {t('contact.title')}
    </h2>
    <p class="mt-4 text-lg leading-8 text-gray-300">
      {t('contact.subtitle')}
    </p>
    <div class="mt-4 h-1 w-20 bg-primary-500 rounded mx-auto"></div>
  </div>

  <div class="mx-auto mt-16 max-w-3xl sm:mt-20">
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      <!-- Email Card -->
      <a
        href={`mailto:${email}`}
        class="contact-card group flex flex-col items-center gap-y-3 rounded-2xl bg-gray-800 p-8 ring-1 ring-gray-700 hover:ring-primary-500 hover:shadow-lg hover:shadow-primary-500/10 transition-all duration-300"
      >
        <div
          class="flex h-12 w-12 items-center justify-center rounded-full bg-primary-900/40 group-hover:bg-primary-900/60 transition-colors"
        >
          <svg
            class="h-6 w-6 text-primary-400"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.5"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
            ></path>
          </svg>
        </div>
        <h3 class="text-base font-semibold text-white">Email</h3>
        <p class="text-sm text-primary-400 select-all cursor-pointer">
          {email}
        </p>
        <span
          class="text-xs text-gray-500 group-hover:text-gray-400 transition-colors"
        >
          {t('contact.clickToEmail')}
        </span>
      </a>

      <!-- LinkedIn Card -->
      <a
        href={linkedinUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="contact-card group flex flex-col items-center gap-y-3 rounded-2xl bg-gray-800 p-8 ring-1 ring-gray-700 hover:ring-[#0A66C2] hover:shadow-lg hover:shadow-[#0A66C2]/10 transition-all duration-300"
      >
        <div
          class="flex h-12 w-12 items-center justify-center rounded-full bg-[#0A66C2]/20 group-hover:bg-[#0A66C2]/30 transition-colors"
        >
          <svg
            class="h-6 w-6 text-[#0A66C2]"
            fill="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
            ></path>
          </svg>
        </div>
        <h3 class="text-base font-semibold text-white">LinkedIn</h3>
        <p class="text-sm text-[#0A66C2] select-all">/in/tan-phat-vo</p>
        <p class="text-xs text-slate-400 text-center px-2">
          Senior Backend Engineer @ ANZ Bank · .NET · Golang · GCP
        </p>
        <span
          class="text-xs text-gray-500 group-hover:text-gray-400 transition-colors"
        >
          {t('contact.viewProfile')}
        </span>
      </a>

      <!-- WhatsApp Card -->
      <div
        class="contact-card-qr group relative flex flex-col items-center gap-y-3 rounded-2xl bg-gray-800 p-8 ring-1 ring-gray-700 hover:ring-[#25D366] hover:shadow-lg hover:shadow-[#25D366]/10 transition-all duration-300"
      >
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="flex flex-col items-center gap-y-3 w-full"
        >
          <div
            class="flex h-12 w-12 items-center justify-center rounded-full bg-[#25D366]/20 group-hover:bg-[#25D366]/30 transition-colors"
          >
            <svg
              class="h-6 w-6 text-[#25D366]"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              ></path>
            </svg>
          </div>
          <h3 class="text-base font-semibold text-white">WhatsApp</h3>
          <p class="text-sm text-[#25D366] select-all">{phoneDisplay}</p>
        </a>

        <!-- QR Tooltip on hover -->
        <div
          class="qr-tooltip absolute -top-48 left-1/2 -translate-x-1/2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-50"
        >
          <div
            class="bg-gray-900 rounded-xl p-3 shadow-2xl ring-1 ring-gray-700"
          >
            <p class="text-xs text-gray-400 text-center mb-2">
              {t('contact.scanToChat')}
            </p>
            <img
              src={whatsappQr}
              alt="WhatsApp QR"
              width="140"
              height="140"
              class="rounded-lg"
              loading="lazy"
            />
          </div>
          <div
            class="absolute left-1/2 -translate-x-1/2 -bottom-2 w-4 h-4 bg-gray-900 rotate-45 ring-1 ring-gray-700 ring-offset-0"
          >
          </div>
        </div>

        <span
          class="text-xs text-gray-500 group-hover:text-gray-400 transition-colors"
        >
          {t('contact.hoverQrClick')}
        </span>
      </div>

      <!-- Zalo Card -->
      <div
        class="contact-card-qr group relative flex flex-col items-center gap-y-3 rounded-2xl bg-gray-800 p-8 ring-1 ring-gray-700 hover:ring-[#0068FF] hover:shadow-lg hover:shadow-[#0068FF]/10 transition-all duration-300"
      >
        <a
          href={zaloUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="flex flex-col items-center gap-y-3 w-full"
        >
          <div
            class="flex h-12 w-12 items-center justify-center rounded-full bg-[#0068FF]/20 group-hover:bg-[#0068FF]/30 transition-colors"
          >
            <span class="text-lg font-bold text-[#0068FF]">Z</span>
          </div>
          <h3 class="text-base font-semibold text-white">Zalo</h3>
          <p class="text-sm text-[#0068FF] select-all">{phoneDisplay}</p>
        </a>

        <!-- QR Tooltip on hover -->
        <div
          class="qr-tooltip absolute -top-48 left-1/2 -translate-x-1/2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 z-50"
        >
          <div
            class="bg-gray-900 rounded-xl p-3 shadow-2xl ring-1 ring-gray-700"
          >
            <p class="text-xs text-gray-400 text-center mb-2">
              {t('contact.scanToChat')}
            </p>
            <img
              src={zaloQr}
              alt="Zalo QR"
              width="140"
              height="140"
              class="rounded-lg"
              loading="lazy"
            />
          </div>
          <div
            class="absolute left-1/2 -translate-x-1/2 -bottom-2 w-4 h-4 bg-gray-900 rotate-45 ring-1 ring-gray-700 ring-offset-0"
          >
          </div>
        </div>

        <span
          class="text-xs text-gray-500 group-hover:text-gray-400 transition-colors"
        >
          {t('contact.hoverQrClick')}
        </span>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-card-qr {
    overflow: visible;
  }
</style>
